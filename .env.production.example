# ── Lumina Waves production env (copy to `.env` on the server; never commit `.env`) ──

# Your domain (DNS A-record must point at this server's IP). Used by Caddy for TLS.
DOMAIN=app.example.com

# Postgres — the compose `db` service uses this password; DATABASE_URL must match.
POSTGRES_PASSWORD=change-me-strong-db-password
DATABASE_URL=postgresql://lumina:change-me-strong-db-password@db:5432/lumina

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET=change-me-openssl-rand-base64-32
# Required when self-hosting behind a reverse proxy (Caddy) — Auth.js v5 rejects
# the host otherwise (UntrustedHost). Leave as true for this deployment.
AUTH_TRUST_HOST=true

# First admin (seeded by `prisma db seed` / provisioning). Change after first login.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-strong-admin-password

# Internal services (compose network hostnames).
REDIS_URL=redis://redis:6379
MEILI_HOST=http://meili:7700
MEILI_KEY=change-me-strong-meili-key

# File storage (shared volume mounted into web + worker).
STORAGE_DIR=/app/.storage

# OCR engine (tesseract.js, bundled — no system package needed).
OCR_PROVIDER=tesseract

# ── Optional features (degrade gracefully if blank) ──
# Transactional email (soft-delete alerts). Pick ONE provider for SMTP_URL.
# NOTE: Zoho Mail's free tier is webmail-only (no external SMTP), so app sending
# uses a transactional service. URL-encode any special chars in the password.
#
#   Resend:     SMTP_URL=smtps://resend:<RESEND_API_KEY>@smtp.resend.com:465
#   ZeptoMail:  SMTP_URL=smtps://emailapikey:<ZEPTO_SEND_TOKEN>@smtp.zeptomail.com:465
#               (use smtp.zeptomail.eu if your ZeptoMail account is in the EU DC)
SMTP_URL=
MAIL_FROM=ops@luminawaves.com
ALERT_EMAIL=ops@luminawaves.com
# Google Drive backup mirror — leave blank to disable.
DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# Web push (VAPID). Generate with: npx web-push generate-vapid-keys
# Use the REAL production keypair here (not the dev/CI throwaway).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@luminawaves.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
