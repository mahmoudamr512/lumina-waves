# Auto-HTTPS reverse proxy. DOMAIN comes from the environment (compose passes it).
# Caddy fetches a Let's Encrypt certificate automatically once DOMAIN's DNS
# points at this server.
{$DOMAIN} {
	encode zstd gzip
	reverse_proxy web:3000
}

# Redirect the www host to the apex (gets its own cert; needs an A record for www).
www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}
